# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aetherflow-rag

# OpenAI-compatible AI provider
AI_PROVIDER_NAME=9Router
AI_PROVIDER_BASE_URL=https://9router.oryfikry.space/v1
AI_PROVIDER_API_KEY=
AI_CHAT_MODEL=combo-orak-arik
AI_PROVIDER_TIMEOUT_MS=30000

# Cohere embedding provider for RAG
AI_EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v1
COHERE_EMBEDDING_MODEL=embed-v4.0
COHERE_INPUT_TYPE=search_query

# Only used if AI_EMBEDDING_PROVIDER=openai-compatible
AI_EMBEDDING_MODEL=

# Supabase frontend auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase backend-only access
SUPABASE_SERVICE_ROLE_KEY=

# Optional later
SUPABASE_STORAGE_BUCKET=
SUPABASE_JWT_SECRET=

# Local API
API_PORT=4000
WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
